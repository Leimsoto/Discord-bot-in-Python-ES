# ════════════════════════════════════════════════════════════
#  TortuguBot — Configuración de entorno (.env)
#  Copia este archivo como .env y completa los valores
# ════════════════════════════════════════════════════════════

# ── Discord ───────────────────────────────────────────────────────────────────
# Token del bot (requerido) — https://discord.com/developers/applications
TOKEN=TU_TOKEN_AQUI


# ── Base de datos ─────────────────────────────────────────────────────────────
# Opciones: sqlite | postgresql | mariadb
# Por defecto: sqlite  (no requiere configuración adicional)
DB_TYPE=sqlite

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=postgresql
#
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db

# ── MariaDB / MySQL ───────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=mariadb
#
# DB_TYPE=mariadb
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=bot_user
# DB_PASSWORD=contraseña
# DB_NAME=bot_db


# ── Inteligencia Artificial (Google Gemini) ───────────────────────────────────
# API Key — Obtenerla en https://aistudio.google.com/app/apikey (gratis)
# GEMINI_API_KEY=AIzaSy...

# ── System Prompt global (opcional) ──────────────────────────────────────────
# Personalidad base del bot. Puede sobreescribirse por servidor desde Discord
# usando /iaconfig → botón "System Prompt".
# Si no se define aquí, se usa el default hardcoded del módulo.
#
# AI_SYSTEM_PROMPT="Eres un asistente amigable llamado TortuguBot. Puedes analizar imágenes, documentos y audio. Usa Google Search para información actual."

# ── Rate Limiting (token bucket — 1 slot por REQUEST, no por token LLM) ──────
#
# Límites del free tier por modelo (abril 2026):
#   gemini-2.5-flash-lite → 15 RPM / 1 000 req/día  ← primario
#   gemini-2.5-flash      → 10 RPM /   250 req/día  ← fallback
#   gemini-2.5-pro        →  5 RPM /   100 req/día  ← último recurso
#
# AI_RATE_CAPACITY=10      # Requests máximos permitidos por periodo (default: 10)
# AI_RATE_PERIOD=60        # Duración del periodo en segundos       (default: 60)

# ── Concurrencia ──────────────────────────────────────────────────────────────
# AI_CONCURRENCY=2         # Llamadas paralelas a la API             (default: 2)
# AI_QUEUE_SIZE=64         # Tamaño máximo de la cola de peticiones  (default: 64)

# ── Cooldown por usuario ──────────────────────────────────────────────────────
# AI_MIN_USER_INTERVAL=4.0 # Segundos mínimos entre consultas/usuario (default: 4.0)


# ── Panel Web (OAuth2 Discord) ───────────────────────────────────────────────
# Necesarios cuando configures el dashboard web.
# Usa el mismo Application de https://discord.com/developers/applications
# donde tienes tu bot.
#
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=tu_client_secret_aqui

# ── JWT (sesión del panel web) ────────────────────────────────────────────────
# Genera una clave aleatoria con: python -c "import secrets; print(secrets.token_hex(32))"
# Sin esta clave, la API funciona en modo desarrollo (sin autenticación).
# JWT_SECRET=

# ── URL del Dashboard ─────────────────────────────────────────────────────────
# URL del frontend del panel web. Se usa para CORS y redirect de OAuth2.
# DASHBOARD_URL=http://localhost:3000
