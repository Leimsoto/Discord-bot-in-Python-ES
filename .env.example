# Token del bot de Discord (requerido)
TOKEN=TU_TOKEN_AQUI


# ── Base de datos ─────────────────────────────────────────────────────────────
# Opciones: sqlite | postgresql | mariadb
# Por defecto: sqlite  (no requiere configuración adicional)

DB_TYPE=sqlite

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=postgresql
#
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db

# ── MariaDB / MySQL ───────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=mariadb
#
# DB_TYPE=mariadb
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=bot_user
# DB_PASSWORD=contraseña
# DB_NAME=bot_db

# ── Inteligencia Artificial (Gemini) ──────────────────────────────────────────
# API Key de Google Gemini (Obtenla en https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIzaSy...

# Prompt del Sistema base para el bot (Opcional, puede sobrescribirse dinámicamente)
# AI_SYSTEM_PROMPT="Eres un asistente amigable y útil llamado TortuguBot. Si te hacen preguntas de actualidad, usa Google Search para responder."
